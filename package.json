{
  "name": "@kungfusaini/pi-plan-mode",
  "version": "0.1.0",
  "description": "Read-only plan mode and XDG-backed durable project plans for the Pi coding agent",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kungfusaini/pi-plan-mode.git"
  },
  "homepage": "https://github.com/kungfusaini/pi-plan-mode#readme",
  "bugs": {
    "url": "https://github.com/kungfusaini/pi-plan-mode/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "plan-mode",
    "planning",
    "coding-agent"
  ],
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "check": "npm run typecheck && npm test",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@earendil-works/pi-tui": "^0.80.6",
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typebox": "^1.0.0",
    "typescript": "^5.9.0"
  }
}
